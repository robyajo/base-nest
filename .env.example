# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
APP_URL=http://localhost:8000
PORT=8000
CORS_ORIGIN=*
CLIENT_URL=http://localhost:8000
VERIFICATION_COOLDOWN=60

# ──────────────────────────────────────────────
# Google OAuth (opsional — kosongkan jika tidak pakai)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback

# ──────────────────────────────────────────────
# Discord OAuth (opsional — kosongkan jika tidak pakai)
# ──────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:8000/api/v1/auth/discord/callback

# ──────────────────────────────────────────────
# Mail / SMTP (opsional — kosongkan jika tidak pakai)
# ──────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@example.com
