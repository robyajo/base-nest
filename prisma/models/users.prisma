model User {
    id                 String              @id @default(cuid())
    username           String              @unique
    email              String              @unique
    displayName        String?
    isActive           Boolean             @default(true)
    passwordHash       String?
    googleId           String?             @unique
    discordId          String?             @unique
    avatarUrl          String?
    provider           String              @default("email")
    emailVerified      Boolean             @default(false)
    emailVerifiedAt    DateTime?
    role               UserRole            @default(USER)
    createdAt          DateTime            @default(now())
    updatedAt          DateTime            @updatedAt
    posts              Post[]
    profile            Profile?
    apiTokens          ApiToken[]
    refreshTokens      RefreshToken[]
    verificationTokens VerificationToken[]
    loginLogs          LoginLog[]
}

enum UserRole {
    USER
    ADMIN
}

model Profile {
    id        String  @id @default(cuid())
    bio       String?
    whatsapp  String?
    instagram String?
    tiktok    String?
    youtube   String?
    website   String?
    userId    String  @unique
    user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiToken {
    id         String    @id @default(cuid())
    userId     String
    name       String
    token      String    @unique
    scopes     String[]
    lastUsedAt DateTime?
    expiresAt  DateTime?
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
    id        String   @id @default(cuid())
    tokenHash String   @unique
    userId    String
    expiresAt DateTime
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([tokenHash])
}

model VerificationToken {
    id        String   @id @default(cuid())
    token     String   @unique
    userId    String
    type      String   @default("EMAIL_VERIFICATION")
    expiresAt DateTime
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([token])
}

model LoginLog {
    id        String   @id @default(cuid())
    userId    String
    method    String
    ip        String?
    userAgent String?
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([createdAt])
}
